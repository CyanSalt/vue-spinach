{
  "name": "vue-spinach",
  "version": "0.1.0-beta.4",
  "description": "Transform Vue SFC between Option API and Composition API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "vue-spinach": "./dist/cli.mjs"
  },
  "scripts": {
    "lint": "eslint --fix './**/*.{js,ts,vue}'",
    "lint:ci": "eslint --max-warnings 0 './**/*.{js,ts,vue}'",
    "prepack": "tsdown",
    "release": "pnpm run release --preRelease=beta --npm.tag=latest",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyanSalt/vue-spinach.git"
  },
  "keywords": [
    "vue",
    "composition-api"
  ],
  "author": "CyanSalt",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CyanSalt/vue-spinach/issues"
  },
  "homepage": "https://github.com/CyanSalt/vue-spinach#readme",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^11.0.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "onFail": "ignore"
      }
    ]
  },
  "devDependencies": {
    "@cyansalt/eslint-config": "^4.6.0",
    "@cyansalt/tsconfig": "^3.0.2",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.12.3",
    "@vue-macros/reactivity-transform": "^3.1.2",
    "eslint": "^10.3.0",
    "lodash-es": "^4.18.1",
    "release-it": "^20.0.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.5",
    "vue": "^3.5.34"
  },
  "dependencies": {
    "@babel/types": "^7.29.0",
    "@vue/compiler-sfc": "^3.5.34",
    "ast-kit": "^2.2.0",
    "magic-string-ast": "^1.0.3",
    "minimist": "^1.2.8"
  }
}
